@page "/history"
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@using Microsoft.Data.SqlClient
@inject IConfiguration Configuration

<div style="display:flex; height:100vh; font-family:sans-serif;">

  <!-- SIDEBAR -->
  <div style="width:200px; background:white; border-right:0.5px solid #e0e0e0; display:flex; flex-direction:column; padding:1.25rem 0; flex-shrink:0;">
    <div style="font-size:14px; font-weight:500; padding:0 1.25rem 1.25rem; border-bottom:0.5px solid #e0e0e0; margin-bottom:0.75rem;">
      Health Dashboard
      <span style="font-size:11px; color:gray; display:block; font-weight:400; margin-top:2px;">Microservices Monitor</span>
    </div>
    <a href="/dashboard" style="text-decoration:none; display:flex; align-items:center; gap:8px; padding:8px 1.25rem; font-size:13px; color:gray;">
      <div style="width:7px; height:7px; border-radius:50%; background:#ccc;"></div>
      Services
    </a>
    <div style="display:flex; align-items:center; gap:8px; padding:8px 1.25rem; font-size:13px; font-weight:500; background:#f5f5f5; border-left:2px solid #639922;">
      <div style="width:7px; height:7px; border-radius:50%; background:#639922;"></div>
      History
    </div>
    <div style="display:flex; align-items:center; gap:8px; padding:8px 1.25rem; font-size:13px; color:gray;">
      <div style="width:7px; height:7px; border-radius:50%; background:#ccc;"></div>
      Settings
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div style="flex:1; overflow-y:auto; padding:1.5rem; display:flex; flex-direction:column; gap:1rem; background:#fafafa;">

    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div style="font-size:16px; font-weight:500;">Health History</div>
      <div style="font-size:11px; color:gray;">All time</div>
    </div>

    @if (isLoading)
    {
      <p style="font-size:13px; color:gray;">Loading...</p>
    }
    else if (errorMessage != null)
    {
      <div style="background:#FCEBEB; border:0.5px solid #F7C1C1; border-radius:8px; padding:10px 14px; font-size:13px; color:#A32D2D;">
        @errorMessage
      </div>
    }
    else if (logs.Count == 0)
    {
      <p style="font-size:13px; color:gray;">No records found.</p>
    }
    else
    {
      <div style="background:white; border-radius:8px; border:0.5px solid #e0e0e0; overflow:hidden;">
        <table style="width:100%; border-collapse:collapse; font-size:13px;">
          <thead>
            <tr style="border-bottom:0.5px solid #e0e0e0; background:#fafafa;">
              <th style="text-align:left; padding:10px 14px; font-weight:500; color:gray;">Service</th>
              <th style="text-align:left; padding:10px 14px; font-weight:500; color:gray;">Status</th>
              <th style="text-align:left; padding:10px 14px; font-weight:500; color:gray;">Response Time</th>
              <th style="text-align:left; padding:10px 14px; font-weight:500; color:gray;">Error</th>
              <th style="text-align:left; padding:10px 14px; font-weight:500; color:gray;">Timestamp</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var log in logs)
            {
              <tr style="border-bottom:0.5px solid #f0f0f0;">
                <td style="padding:10px 14px; font-weight:500;">@log.ServiceId</td>
                <td style="padding:10px 14px;">
                  <span style="font-size:11px; font-weight:500; padding:3px 10px; border-radius:20px; background:@GetBadgeBg(log.Status); color:@GetBadgeColor(log.Status);">
                    @log.Status
                  </span>
                </td>
                <td style="padding:10px 14px; color:gray;">@(log.ResponseTimeMs > 0 ? $"{log.ResponseTimeMs}ms" : "—")</td>
                <td style="padding:10px 14px; color:#A32D2D; font-size:12px;">@(log.ErrorMessage == "No error" ? "—" : log.ErrorMessage)</td>
                <td style="padding:10px 14px; color:gray;">@log.Timestamp.ToString("MMM dd, yyyy hh:mm tt")</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }

  </div>
</div>

@code {
    private List<HealthLog> logs = new();
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        isLoading = true;
        try
        {
            var connectionString = Configuration.GetConnectionString("MicroserviceDb");
            using var connection = new SqlConnection(connectionString);
            await connection.OpenAsync();

            var sql = "SELECT ServiceId, Status, ResponseTimeMs, ErrorMessage, Timestamp FROM HealthLogs ORDER BY Timestamp DESC";
            using var command = new SqlCommand(sql, connection);
            using var reader = await command.ExecuteReaderAsync();

            logs = new List<HealthLog>();
            while (await reader.ReadAsync())
            {
                logs.Add(new HealthLog
                {
                    ServiceId = reader.GetString(0),
                    Status = reader.GetString(1),
                    ResponseTimeMs = reader.GetInt32(2),
                    ErrorMessage = reader.IsDBNull(3) ? null : reader.GetString(3),
                    Timestamp = reader.GetDateTime(4)
                });
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load history: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetBadgeBg(string status) => status == "Healthy" ? "#EAF3DE" : status == "Degraded" ? "#FAEEDA" : "#FCEBEB";
    private string GetBadgeColor(string status) => status == "Healthy" ? "#3B6D11" : status == "Degraded" ? "#854F0B" : "#A32D2D";

    public class HealthLog
    {
        public string ServiceId { get; set; } = "";
        public string Status { get; set; } = "";
        public int ResponseTimeMs { get; set; }
        public string? ErrorMessage { get; set; }
        public DateTime Timestamp { get; set; }
    }
}